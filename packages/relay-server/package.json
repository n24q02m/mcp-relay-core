{
  "name": "@n24q02m/mcp-relay-server",
  "version": "1.0.2",
  "description": "Zero-config MCP credential relay server — ECDH P-256 + AES-256-GCM, rate-limited, zero-knowledge",
  "keywords": [
    "mcp",
    "relay",
    "server",
    "credentials",
    "encryption",
    "zero-knowledge"
  ],
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n24q02m/mcp-relay-core.git",
    "directory": "packages/relay-server"
  },
  "homepage": "https://github.com/n24q02m/mcp-relay-core",
  "bugs": {
    "url": "https://github.com/n24q02m/mcp-relay-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "vitest --passWithNoTests",
    "test:coverage": "vitest --coverage",
    "check": "biome check . && bun run type-check",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "bun@1.2.21"
}
