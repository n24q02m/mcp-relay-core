{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "module": "es2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "build",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}
